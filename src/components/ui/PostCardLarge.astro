---
import { BLOG_BASE } from '../../lib/postUrl';
interface Props {
  title: string;
  description: string;
  slug: string;
  heroImage?: string;
  category?: string;
  pubDate: Date;
}

const { title, description, slug, heroImage, category, pubDate } = Astro.props;

const url = `${BLOG_BASE}/${slug}`;
const date = pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: '2-digit' }).replace('.', '');
---

<article class="group bg-surface border border-border rounded-md overflow-hidden" style="box-shadow: 0 1px 2px 0 rgba(80, 40, 20, 0.04)">
  {heroImage && (
    <a href={url} class="block overflow-hidden aspect-[16/9]" tabindex="-1" aria-hidden="true">
      <img
        src={heroImage}
        alt=""
        loading="lazy"
        class="w-full h-full object-cover transition-opacity duration-200 group-hover:opacity-90"
      />
    </a>
  )}
  {!heroImage && (
    <div class="aspect-[16/9] bg-elev"></div>
  )}

  <div class="p-5 md:p-6">
    {category && (
      <p class="mono uppercase text-xs text-ink-faint mb-2">{category}</p>
    )}
    <h2 class="font-display font-normal text-xl leading-snug tracking-tight line-clamp-2">
      <a href={url} class="text-ink hover:text-primary transition-colors">{title}</a>
    </h2>
    <p class="text-sm text-ink-muted leading-relaxed line-clamp-3 mt-2">{description}</p>
    <div class="flex items-center justify-between mt-4 pt-4 border-t border-rule">
      <span class="mono text-xs text-ink-faint">{date}</span>
      <a href={url} class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-ink transition-colors">
        Ler
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</article>
