---
import { BLOG_BASE } from '../../lib/postUrl';
interface Props {
  title: string;
  description: string;
  slug: string;
  heroImage?: string;
  category?: string;
  pubDate: Date;
}

const { title, description, slug, heroImage, category, pubDate } = Astro.props;
---

<article class="group bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-gray-200 hover:shadow-md transition-all">
  <!-- Imagem -->
  <a href={`${BLOG_BASE}/${slug}`} class="block overflow-hidden aspect-[16/9]">
    {heroImage ? (
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-gray-100 to-primary-50"></div>
    )}
  </a>

  <!-- Conteúdo -->
  <div class="p-4">
    {category && (
      <span class="inline-block bg-primary-500 text-white text-xs font-bold px-2.5 py-0.5 rounded-full mb-2 uppercase tracking-wide">
        {category}
      </span>
    )}
    <h3 class="font-bold text-slate-800 text-sm leading-snug line-clamp-2 group-hover:text-primary-500 transition-colors mb-2">
      <a href={`${BLOG_BASE}/${slug}`}>{title}</a>
    </h3>
    <p class="text-slate-500 text-xs leading-relaxed line-clamp-2">{description}</p>
    <p class="text-slate-400 text-xs mt-3 post-date">
      {pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
    </p>
  </div>
</article>
