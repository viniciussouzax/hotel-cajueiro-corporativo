---
/**
 * LocalHome.astro — Home do Hotel Cajueiro (frontend novo, data-driven).
 *
 * Mantém a camada de dados original (loadHomeData / localHome.json / localBusiness.json),
 * editável pelo admin. Apenas o markup/visual foi atualizado para o design aprovado.
 * Header e Footer continuam vindo do BaseLayout.
 *
 * Seções data-driven : hero, como reservar (steps), para quem é (homeServices),
 *                       estrutura (amenities), sobre (aboutParas), FAQ, CTA final.
 * Seções fixas (novas): barra de aviso, acomodações, galeria, "onde estamos".
 *                       Conteúdo no próprio arquivo — migrável ao admin depois.
 */
import { loadHomeData, type HomePreview } from '../../lib/localHomeData';
import CajuButton from '../CajuButton.astro';
import ImgSlot from '../ImgSlot.astro';

interface Props { preview?: HomePreview }
const { preview } = Astro.props as Props;

const d = loadHomeData(preview);
const {
  homeServices, region, company, cities,
  waUrl, biz, heroTitle, heroSubtitle, aboutParas,
  steps, labels, show, ctaTitle, ctaSubtitle, ctaButton,
  amenities, faq, empty, serviceHref,
} = d;

// E-mail de contato: usa biz.email se existir, senão o padrão do hotel.
const email = (biz as any).email || 'corporativo@hotelcajueiroguaruja.com.br';
const waNumber = String((biz as any).whatsapp || '').replace(/\D/g, '');

// Ícones de linha por amenidade (inner SVG injetado via set:html).
const AICON: Record<string, string> = {
  coffee: '<path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4.5"/><line x1="10" y1="2" x2="10" y2="4.5"/><line x1="14" y1="2" x2="14" y2="4.5"/>',
  dinner: '<path d="M5 3v6a2 2 0 1 0 4 0V3"/><line x1="7" y1="9" x2="7" y2="21"/><path d="M17 3v18"/><path d="M17 3c-1.7 0-3 1.9-3 4.5S15.3 12 17 12"/>',
  pool: '<path d="M2 16c1.5 0 1.5-1.5 3-1.5s1.5 1.5 3 1.5 1.5-1.5 3-1.5 1.5 1.5 3 1.5 1.5-1.5 3-1.5 1.5 1.5 3 1.5"/><path d="M2 11c1.5 0 1.5-1.5 3-1.5s1.5 1.5 3 1.5 1.5-1.5 3-1.5 1.5 1.5 3 1.5 1.5-1.5 3-1.5 1.5 1.5 3 1.5"/>',
  ac: '<line x1="12" y1="2" x2="12" y2="22"/><line x1="4" y1="6.5" x2="20" y2="17.5"/><line x1="20" y1="6.5" x2="4" y2="17.5"/>',
  wifi: '<path d="M2 8.8a15 15 0 0 1 20 0"/><path d="M5 12.5a10 10 0 0 1 14 0"/><path d="M8.5 16a5 5 0 0 1 7 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
  parking: '<rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 17V7h3.5a3 3 0 0 1 0 6H9"/>',
  bed: '<path d="M2 4v16"/><path d="M2 9h16a3 3 0 0 1 3 3v8"/><path d="M2 16h19"/><path d="M6 9V6h6v3"/>',
  clock: '<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/>',
  invoice: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/>',
  tag: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>',
  beach: '<circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"/>',
  port: '<circle cx="12" cy="4.5" r="2.5"/><line x1="12" y1="7" x2="12" y2="22"/><path d="M5 13H2a10 10 0 0 0 20 0h-3"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  landmark: '<line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7"/>',
  ship: '<path d="M12 10.189V14"/><path d="M12 2v3"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-8.188-3.639a2 2 0 0 0-1.624 0L3 14a11.6 11.6 0 0 0 2.81 7.76"/><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1 .6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>',
  flag: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>',
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  aid: '<path d="M11 2a2 2 0 0 0-2 2v5H4a2 2 0 0 0-2 2v2a2 2 0 0 0 2 2h5v5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-5h5a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-5V4a2 2 0 0 0-2-2z"/>',
  route: '<circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/>',
  fridge: '<rect x="5.5" y="2.5" width="13" height="19" rx="2"/><line x1="5.5" y1="10" x2="18.5" y2="10"/><line x1="8.5" y1="6" x2="8.5" y2="7.5"/><line x1="8.5" y1="13" x2="8.5" y2="15"/>',
  linen: '<rect x="3" y="6.5" width="18" height="4.5" rx="1.2"/><rect x="3" y="13" width="18" height="4.5" rx="1.2"/><line x1="7" y1="6.5" x2="7" y2="11"/><line x1="7" y1="13" x2="7" y2="17.5"/>',
  clean: '<path d="m12 3 1.7 4.8L18.5 9.5l-4.8 1.7L12 16l-1.7-4.8L5.5 9.5l4.8-1.7L12 3Z"/><path d="M18.5 14.5v3M17 16h3"/>',
  laptop: '<path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/>',
  closet: '<path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/>',
  blinds: '<path d="M3 3h18"/><path d="M20 7H8"/><path d="M20 11H8"/><path d="M10 19h10"/><path d="M8 15h12"/><path d="M4 3v14"/><circle cx="4" cy="19" r="2"/>',
  water: '<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>',
  default: '<polyline points="20 6 9 17 4 12"/>',
};

// SVG do ícone do WhatsApp (reutilizado nos botões).
const WA = '<path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.5-3.9-4.7-4.1-.1-.2-1-1.4-1-2.6s.6-1.8.9-2.1c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.4.6c-.1.2-.3.3-.1.6.1.3.7 1.1 1.4 1.7.9.8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.7-.8c.2-.2.3-.2.6-.1l1.8.9c.3.1.5.2.5.3.1.1.1.7-.1 1.3Z"/>';

// Ícones de linha por tipo de público (cards "para quem é"), por índice:
// 0 Viagens corporativas (maleta) · 1 Projetos e obras (capacete) · 2 Relocação/longa permanência (casa).
const SVCICON = [
  // Lucide "plane" — Viagens corporativas (✈️)
  '<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>',
  // Lucide "hard-hat" — Projetos e obras (🏗️)
  '<path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M14 6a6 6 0 0 1 6 6v3"/><path d="M4 15v-3a6 6 0 0 1 6-6"/><rect x="2" y="15" width="20" height="4" rx="1"/>',
  // Lucide "globe" — Relocação e longa permanência (🌎)
  '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
];

const cityName = cities[0]?.name || region || 'Guarujá';
const mapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent('Hotel Cajueiro ' + (biz.address || ''))}`;
const mapEmbedSrc = `https://www.google.com/maps?q=${encodeURIComponent('Hotel Cajueiro ' + (biz.address || 'Guarujá'))}&z=15&output=embed`;
---

<!-- A barra de aviso fica no Header.astro (acima da nav, global). -->

<!-- ===================== HERO ===================== -->
<section class="bg-bg">
  <div class="container-x pt-12 md:pt-16 pb-14 md:pb-20">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-cat-terracota mb-5">A 100m da Praia do Tombo</p>
        <h1 class="font-display text-ink text-3xl md:text-4xl lg:text-[48px] font-bold leading-[1.05] tracking-tight">{heroTitle}</h1>
        {heroSubtitle && <p class="text-lg leading-relaxed text-ink-muted mt-6 max-w-xl">{heroSubtitle}</p>}
        <div class="flex flex-col items-start gap-4 mt-8">
          {waUrl && <CajuButton href={waUrl} label={ctaButton} />}
          <span class="text-sm text-ink-faint">Prefere e-mail? <span class="text-primary font-semibold">{email}</span></span>
        </div>
      </div>
      <div class="relative">
        <img src="/images/1.jpg" alt="Fachada do Hotel Cajueiro" width="1000" height="667" loading="eager" class="w-full h-72 md:h-96 lg:h-[500px] object-cover rounded-lg shadow-[0_34px_64px_-30px_rgba(60,45,25,.55)]" />
        <!-- Card flutuante: avaliação Google -->
        <div class="absolute hidden left-3 top-4 md:-left-5 md:top-8 bg-surface rounded-md shadow-[0_20px_40px_-18px_rgba(40,35,20,.5)] px-4 py-3.5">
          <p class="flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0 text-cat-terracota" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10v9a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-9"/></svg>
            <span class="text-base font-bold text-ink">Sinta-se em casa!</span>
          </p>
        </div>
        <!-- Card flutuante: localização -->
        <div class="absolute hidden right-3 bottom-4 md:-right-5 md:bottom-10 bg-primary rounded-md shadow-[0_20px_40px_-18px_rgba(40,45,28,.6)] px-5 py-3.5">
          <p class="text-base font-bold text-bg">Praia do Tombo</p>
          <p class="text-[13px] text-[#cfdcbb] mt-0.5">A 100m do mar, no {cityName}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{empty ? (
  <div class="container-x py-32 text-center">
    <p class="text-xs uppercase tracking-wide text-ink-faint mb-3">comece aqui</p>
    <h2 class="font-display text-3xl text-ink mb-3">Seu site local ainda está vazio.</h2>
    <p class="text-ink-muted">Cadastre serviços e localidades em <a href="/admin/local/services" class="text-primary underline underline-offset-4">Site Local</a> e publique pra gerar as páginas.</p>
  </div>
) : (
  <>
    <!-- ===================== DIFERENCIAIS (logo abaixo da hero) ===================== -->
    <section class="bg-elev border-y border-border">
      <div class="container-x py-10 md:py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
          {[
            { icon: 'invoice', title: 'Contrato flexível', desc: 'Condições especiais para pagamento no ato da reserva ou faturamento por CNPJ, mediante análise prévia.' },
            { icon: 'clock', title: 'Sem fidelidade', desc: 'Não há prazo mínimo obrigatório, podendo ser reservado a partir de uma diária por hóspede.' },
            { icon: 'tag', title: 'Tarifas acessíveis', desc: 'Economia sem abrir mão da qualidade e do mesmo padrão de conforto oferecido ao público de lazer.' },
          ].map((f) => (
            <div class="flex items-start gap-4">
              <span class="shrink-0 w-12 h-12 rounded-[20px] bg-cat-terracota/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-cat-terracota" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={AICON[f.icon] || AICON.default}></svg>
              </span>
              <div>
                <p class="font-display text-base md:text-lg font-bold text-ink leading-snug">{f.title}</p>
                <p class="text-sm text-ink-muted leading-relaxed mt-1">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== COMO RESERVAR ===================== -->
    {show('comoFunciona') && (
      <section id="reservar" class="bg-surface scroll-mt-24">
        <div class="container-x py-16 md:py-24">
          <div class="text-center max-w-2xl mx-auto mb-12 md:mb-14">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-cat-terracota mb-3.5">{labels.comoFunciona.eyebrow}</p>
            <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-ink">{labels.comoFunciona.title}</h2>
          </div>
          <ol class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {steps.map((s, i) => (
              <li>
                <div class="flex items-center gap-4 mb-4">
                  <span class={`inline-flex items-center justify-center w-12 h-12 rounded-[20px] text-xl font-bold ${i === steps.length - 1 ? 'bg-primary text-bg' : 'bg-cat-terracota/15 text-cat-terracota'}`}>{s.n}</span>
                  <span class="flex-1 h-px bg-rule"></span>
                </div>
                <h3 class="text-lg font-bold text-ink mb-2.5">{s.t}</h3>
                <p class="text-ink-muted leading-relaxed">{s.d}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}

    <!-- ===================== PARA QUEM É ===================== -->
    <section id="para-quem" class="bg-bg scroll-mt-24">
      <div class="container-x py-16 md:py-24">
        <div class="max-w-xl mb-12">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-cat-terracota mb-3.5">{labels.servicos.eyebrow}</p>
          <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-ink mb-4">{labels.servicos.title}</h2>
          <p class="text-ink-muted leading-relaxed">O {company} atende empresas e profissionais em diferentes necessidades de hospedagem, da diária à longa permanência.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {homeServices.map((svc, i) => (
            <div class="flex flex-col bg-surface rounded-lg p-7 shadow-[0_22px_44px_-30px_rgba(60,45,25,.45)]">
              <div class="w-14 h-14 rounded-xl bg-cat-terracota/10 flex items-center justify-center mb-6">
                <svg class="w-7 h-7 text-cat-terracota" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={SVCICON[i % 3]}></svg>
              </div>
              <h3 class="font-display text-xl font-bold text-ink leading-tight mb-2.5">{svc.title}</h3>
              {svc.shortDescription && <p class="text-sm text-ink-muted leading-relaxed flex-1">{svc.shortDescription}</p>}
              {svc.tag && <span class="inline-flex self-start items-center mt-5 px-3 py-1.5 rounded-[20px] text-[11px] font-bold uppercase tracking-wide bg-[#55703a] text-bg">{svc.tag}</span>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== ACOMODAÇÕES (fixo) ===================== -->
    <section id="acomodacoes" class="bg-elev scroll-mt-24">
      <div class="container-x py-16 md:py-24">
        <div class="max-w-xl mb-12">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-cat-terracota mb-3.5">Acomodações</p>
          <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-ink mb-4">Suítes pensadas para descansar de verdade</h2>
          <p class="text-ink-muted leading-relaxed">O hotel conta com 62 suítes, todas as acomodações com ar-condicionado, enxoval completo, Wi-Fi e frigobar. Montamos a configuração ideal para a sua equipe, com suítes de casal a tripla.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-bg border border-border rounded-lg overflow-hidden shadow-[0_22px_44px_-32px_rgba(60,45,25,.4)] hover:-translate-y-1 transition-transform duration-300">
            <img src="/images/2.jpg" alt="Suíte com varanda" width="600" height="400" loading="lazy" class="w-full object-cover" style="height:200px" />
            <div class="p-6">
              <h3 class="text-lg font-bold text-ink mb-2">Suíte com varanda</h3>
              <p class="text-sm text-ink-muted leading-relaxed">Cama de casal e uma varanda exclusiva, para quem prefere mais espaço e um ambiente para relaxar ao fim do dia.</p>
            </div>
          </div>
          <div class="bg-bg border border-border rounded-lg overflow-hidden shadow-[0_22px_44px_-32px_rgba(60,45,25,.4)] hover:-translate-y-1 transition-transform duration-300">
            <img src="/images/3.jpg" alt="Suíte casal" width="600" height="400" loading="lazy" class="w-full object-cover" style="height:200px" />
            <div class="p-6">
              <h3 class="text-lg font-bold text-ink mb-2">Suíte casal</h3>
              <p class="text-sm text-ink-muted leading-relaxed">Cama de casal em um ambiente aconchegante, ideal para uma estadia confortável e uma boa noite de sono.</p>
            </div>
          </div>
          <div class="bg-bg border border-border rounded-lg overflow-hidden shadow-[0_22px_44px_-32px_rgba(60,45,25,.4)] hover:-translate-y-1 transition-transform duration-300">
            <img src="/images/4.jpg" alt="Suíte dupla" width="600" height="400" loading="lazy" class="w-full object-cover" style="height:200px" />
            <div class="p-6">
              <h3 class="text-lg font-bold text-ink mb-2">Suíte dupla</h3>
              <p class="text-sm text-ink-muted leading-relaxed">Duas camas de solteiro, ideal para quem viaja acompanhado, prática e confortável para a rotina de trabalho.</p>
            </div>
          </div>
          <div class="bg-bg border border-border rounded-lg overflow-hidden shadow-[0_22px_44px_-32px_rgba(60,45,25,.4)] hover:-translate-y-1 transition-transform duration-300">
            <img src="/images/5.jpg" alt="Suíte dupla com varanda" width="600" height="400" loading="lazy" class="w-full object-cover" style="height:200px" />
            <div class="p-6">
              <h3 class="text-lg font-bold text-ink mb-2">Suíte dupla com varanda</h3>
              <p class="text-sm text-ink-muted leading-relaxed">Duas camas de solteiro com a vantagem de uma varanda exclusiva, para relaxar ao ar livre depois do trabalho.</p>
            </div>
          </div>
          <div class="bg-bg border border-border rounded-lg overflow-hidden shadow-[0_22px_44px_-32px_rgba(60,45,25,.4)] hover:-translate-y-1 transition-transform duration-300">
            <img src="/images/6.jpg" alt="Suíte tripla" width="600" height="400" loading="lazy" class="w-full object-cover" style="height:200px" />
            <div class="p-6">
              <h3 class="text-lg font-bold text-ink mb-2">Suíte tripla</h3>
              <p class="text-sm text-ink-muted leading-relaxed">Três camas em um ambiente amplo, ideal para acomodar a equipe junta, com todo o conforto para o descanso.</p>
            </div>
          </div>
          <div class="bg-[#2C3A20] rounded-lg p-8 flex flex-col">
            <div class="w-12 h-12 rounded-md bg-cat-ocre/15 flex items-center justify-center mb-5">
