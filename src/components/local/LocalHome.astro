            <div class="flex flex-col gap-4 mb-7">
              {[
                { icon: 'ship', t: 'De Santos (Margem Direita)', d: 'Balsa pela Ponta da Praia (cerca de 7 minutos, 24h) ou pela Rodovia Cônego Domênico Rangoni.' },
