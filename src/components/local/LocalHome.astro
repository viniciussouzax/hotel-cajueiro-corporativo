    <!-- ===================== LIGHTBOX DA GALERIA ===================== -->
    <div id="gallery-lightbox" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/90 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Visualizador de imagens">
      <button type="button" id="gallery-close" aria-label="Fechar" class="absolute top-4 right-4 w-11 h-11 inline-flex items-center justify-center rounded-[20px] bg-white/10 text-white hover:bg-white/20 transition-colors">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
      <button type="button" id="gallery-prev" aria-label="Imagem anterior" class="absolute left-3 md:left-6 w-12 h-12 inline-flex items-center justify-center rounded-[20px] bg-white/10 text-white hover:bg-white/20 transition-colors">
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <img id="gallery-img" src="" alt="" class="max-h-[88vh] max-w-[92vw] object-contain rounded-md shadow-2xl select-none" />
      <button type="button" id="gallery-next" aria-label="Próxima imagem" class="absolute right-3 md:right-6 w-12 h-12 inline-flex items-center justify-center rounded-[20px] bg-white/10 text-white hover:bg-white/20 transition-colors">
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <span id="gallery-counter" class="absolute bottom-5 left-1/2 -translate-x-1/2 text-white/80 text-sm font-medium"></span>
    </div>
    <script is:inline>
      (function () {
        var lb = document.getElementById('gallery-lightbox');
        if (!lb) return;
        var imgEl = document.getElementById('gallery-img');
        var counter = document.getElementById('gallery-counter');
        var btns = Array.prototype.slice.call(document.querySelectorAll('[data-gallery-open]'));
        if (!btns.length) return;
        var srcs = btns.map(function (b) { var im = b.querySelector('img'); return im ? im.getAttribute('src') : ''; });
        var alts = btns.map(function (b) { var im = b.querySelector('img'); return im ? (im.getAttribute('alt') || '') : ''; });
        var idx = 0;
        function render() {
          imgEl.setAttribute('src', srcs[idx]);
          imgEl.setAttribute('alt', alts[idx]);
          if (counter) counter.textContent = (idx + 1) + ' / ' + srcs.length;
        }
        function show(i) { idx = (i + srcs.length) % srcs.length; render(); }
        function openAt(i) { show(i); lb.classList.remove('hidden'); lb.classList.add('flex'); document.body.style.overflow = 'hidden'; }
        function close() { lb.classList.add('hidden'); lb.classList.remove('flex'); document.body.style.overflow = ''; }
        btns.forEach(function (b, i) { b.addEventListener('click', function () { openAt(i); }); });
        var prev = document.getElementById('gallery-prev');
        var next = document.getElementById('gallery-next');
        var closeBtn = document.getElementById('gallery-close');
        if (prev) prev.addEventListener('click', function (e) { e.stopPropagation(); show(idx - 1); });
        if (next) next.addEventListener('click', function (e) { e.stopPropagation(); show(idx + 1); });
        if (closeBtn) closeBtn.addEventListener('click', close);
        lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
        document.addEventListener('keydown', function (e) {
          if (lb.classList.contains('hidden')) return;
          if (e.key === 'Escape') close();
          else if (e.key === 'ArrowLeft') show(idx - 1);
          else if (e.key === 'ArrowRight') show(idx + 1);
        });
        var startX = null;
        lb.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; }, { passive: true });
        lb.addEventListener('touchend', function (e) {
          if (startX === null) return;
          var dx = e.changedTouches[0].clientX - startX;
          if (Math.abs(dx) > 40) { show(dx < 0 ? idx + 1 : idx - 1); }
          startX = null;
        }, { passive: true });
      })();
    </script>

    <!-- ===================== MODAL DE CONTATO ===================== -->
    {waUrl && (
      <div id="contact-modal" class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/60 backdrop-blur-sm px-4" role="dialog" aria-modal="true" aria-label="Falar com consultor">
        <div class="bg-[#55703a] rounded-lg shadow-[0_40px_80px_-20px_rgba(0,0,0,.45)] w-full max-w-md p-7 relative">
          <button type="button" id="contact-close" aria-label="Fechar" class="absolute top-3.5 right-3.5 w-9 h-9 inline-flex items-center justify-center rounded-[20px] text-[#eef3e7] hover:bg-white/10 transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
          <h3 class="font-display text-2xl font-bold text-[#F4EEDD] mb-1.5">Fale com um consultor</h3>
          <p class="text-sm text-[#cdd9bf] mb-6 leading-relaxed">Deixe seus dados e um de nossos consultores entrará em contato pelo WhatsApp.</p>
          <form id="contact-form" class="flex flex-col gap-4" data-wa={waNumber}>
            <label class="flex flex-col gap-1.5">
              <span class="text-[13px] font-semibold text-[#F4EEDD]">Nome</span>
              <input name="nome" type="text" required autocomplete="name" placeholder="Seu nome completo" class="h-11 w-full min-w-[200px] px-3.5 rounded-md bg-white text-ink text-[15px] outline-none border-2 border-transparent focus:border-cat-ocre transition-colors" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-[13px] font-semibold text-[#F4EEDD]">E-mail</span>
              <input name="email" type="email" required autocomplete="email" placeholder="seu@email.com.br" class="h-11 w-full min-w-[200px] px-3.5 rounded-md bg-white text-ink text-[15px] outline-none border-2 border-transparent focus:border-cat-ocre transition-colors" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-[13px] font-semibold text-[#F4EEDD]">Telefone (WhatsApp)</span>
              <input name="telefone" type="tel" required inputmode="tel" autocomplete="tel" class="h-11 w-full min-w-[200px] px-3.5 rounded-md bg-white text-ink text-[15px] outline-none border-2 border-transparent focus:border-cat-ocre transition-colors" />
            </label>
            <CajuButton label="Confirmar" submit fullWidth class="mt-1" />
          </form>
        </div>
      </div>
    )}
    <script>
      import intlTelInput from 'intl-tel-input/intlTelInputWithUtils';
      import 'intl-tel-input/styles';
      (function () {
        var modal = document.getElementById('contact-modal');
        if (!modal) return;
        var form = document.getElementById('contact-form');
        var closeBtn = document.getElementById('contact-close');
        var telInput = form ? form.querySelector('input[name="telefone"]') : null;
        var iti = telInput ? intlTelInput(telInput, { initialCountry: 'br', separateDialCode: true, countryOrder: ['br'] }) : null;
        function openModal() { modal.classList.remove('hidden'); modal.classList.add('flex'); document.body.style.overflow = 'hidden'; var first = form && form.querySelector('input'); if (first) setTimeout(function () { try { first.focus(); } catch (e) {} }, 60); }
        function closeModal() { modal.classList.add('hidden'); modal.classList.remove('flex'); document.body.style.overflow = ''; }
        Array.prototype.slice.call(document.querySelectorAll('[data-contact-open]')).forEach(function (b) {
          b.addEventListener('click', function (e) { e.preventDefault(); openModal(); });
        });
        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal(); });
        if (form) form.addEventListener('submit', async function (e) {
          e.preventDefault();
          var submitBtn = form.querySelector('button[type="submit"]');
          var d = new FormData(form);
          var nome = (d.get('nome') || '').toString().trim();
          var tel = (iti && iti.getNumber()) ? iti.getNumber() : (d.get('telefone') || '').toString().trim();
          var email = (d.get('email') || '').toString().trim();
          var wa = form.getAttribute('data-wa') || '';
          var linhas = ['Olá! Gostaria de uma proposta de hospedagem corporativa no Hotel Cajueiro.', ''];
          if (nome) linhas.push('Nome: ' + nome);
          if (tel) linhas.push('Telefone: ' + tel);
          if (email) linhas.push('E-mail: ' + email);
          var waLink = 'https://wa.me/' + wa + '?text=' + encodeURIComponent(linhas.join('\n'));
          if (submitBtn) { submitBtn.setAttribute('disabled', ''); submitBtn.style.opacity = '0.7'; }
          // 1) Envia o contato por e-mail para o hotel (modalidade Corporativo)
          try {
            await fetch('https://formsubmit.co/ajax/corporativo@hotelcajueiroguaruja.com.br', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({
                _subject: 'Corporativo - Nova solicitação de Orçamento (' + (nome || 'sem nome') + ')',
                _template: 'table',
                Modalidade: 'Corporativo',
                Nome: nome,
                Telefone: tel,
                'E-mail': email,
                Origem: 'Formulário do site — Hospedagem Corporativa'
              })
            });
          } catch (err) { /* não bloqueia o redirecionamento */ }
          // 2) Redireciona para o WhatsApp do hotel
          window.location.href = waLink;
        });
      })();
    </script>
  </>
)}
