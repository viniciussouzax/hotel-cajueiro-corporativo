---
/**
 * Footer.astro — rodapé do design aprovado (verde-escuro #26331C, acentos ouro).
 * Data-driven: contato vem de localBusiness/siteConfig; links levam às âncoras da home.
 */
import { readData } from '../../lib/readData';

const siteConfig = readData('siteConfig.json');
const biz = readData('localBusiness.json', {}) as any;

const year = new Date().getFullYear();
const phone = biz.phone || siteConfig.contact?.phone || '';
const phoneHref = phone ? `tel:+55${phone.replace(/\D/g, '')}` : '';
const email = biz.email || siteConfig.contact?.email || 'reservas@hotelcajueiroguaruja.com.br';
const address = biz.address || siteConfig.contact?.address || '';
const brand = (siteConfig.name || 'Hotel Cajueiro').replace(/^Hotel\s+/i, '');

const payments = [
  { label: 'Visa', src: '/images/payments/visa.svg' },
  { label: 'Mastercard', src: '/images/payments/mastercard.svg' },
  { label: 'Elo', src: '/images/payments/elo.svg' },
  { label: 'American Express', src: '/images/payments/amex.svg' },
  { label: 'Hipercard', src: '/images/payments/hipercard.svg' },
  { label: 'Pix', src: '/images/payments/pix.svg' },
  { label: 'Boleto bancário', src: '/images/payments/boleto.svg' },
];
const socials: Array<[string, string]> = ([
  ['Instagram', siteConfig.social?.instagram],
  ['Facebook', siteConfig.social?.facebook],
  ['YouTube', siteConfig.social?.youtube],
  ['LinkedIn', siteConfig.social?.linkedin],
].filter(([, href]) => href)) as any;

const payChip = 'display:inline-flex;align-items:center;justify-content:center;height:30px;width:48px;border-radius:6px;background:#ffffff;box-shadow:0 1px 2px rgba(0,0,0,.22);';
---

<footer style="background:#26331C; color:#c3c8b6;">
  <div class="container-x" style="padding-top:72px;">
    <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10 md:gap-12">
      <!-- Marca + contato -->
      <div>
        <a href="/" class="no-underline inline-block" aria-label={siteConfig.name || 'Hotel Cajueiro'} style="line-height:0; margin-bottom:18px;">
          <img src={siteConfig.logo} alt={siteConfig.name || 'Hotel Cajueiro'} style="height:50px; width:auto; filter:brightness(0) invert(1);" />
        </a>
        <p style="font-size:14px; line-height:1.65; color:#a7ad99; margin:14px 0 22px; max-width:300px;">
          Hospedagem corporativa no Guarujá, Santos e Baixada Santista: conforto de hotel de praia para sua equipe, com café da manhã, jantar opcional e faturamento para empresas.
        </p>
        <div style="display:flex; flex-direction:column; gap:10px; font-size:14px; color:#bcc1ad;">
          {address && (
            <div style="display:flex; gap:10px; align-items:flex-start;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#C8A24A" stroke-width="1.7" style="margin-top:2px; flex:none;" aria-hidden="true"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{address}</span>
            </div>
          )}
          {phone && (
            <div style="display:flex; gap:10px; align-items:center;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#C8A24A" stroke-width="1.7" style="flex:none;" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.8a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z"/></svg>
              <a href={phoneHref} class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">{phone}</a>
            </div>
          )}
          {email && (
            <div style="display:flex; gap:10px; align-items:center;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#C8A24A" stroke-width="1.7" style="flex:none;" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
              <a href={`mailto:${email}`} class="no-underline break-all text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">{email}</a>
            </div>
          )}
        </div>
      </div>

      <!-- Hospedagem -->
      <div>
        <div style="font-size:11px; letter-spacing:.14em; text-transform:uppercase; font-weight:700; color:#8a9079; margin-bottom:18px;">Hospedagem</div>
        <div class="flex flex-col gap-3" style="font-size:14px;">
          <a href="/#para-quem" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Viagens corporativas</a>
          <a href="/#para-quem" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Projetos e obras</a>
          <a href="/#para-quem" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Longa permanência</a>
        </div>
      </div>

      <!-- O hotel -->
      <div>
        <div style="font-size:11px; letter-spacing:.14em; text-transform:uppercase; font-weight:700; color:#8a9079; margin-bottom:18px;">O hotel</div>
        <div class="flex flex-col gap-3" style="font-size:14px;">
          <a href="/#estrutura" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Estrutura</a>
          <a href="/#sobre" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Quem somos</a>
        </div>
      </div>

      <!-- Formas de pagamento -->
      <div>
        <div style="font-size:11px; letter-spacing:.14em; text-transform:uppercase; font-weight:700; color:#8a9079; margin-bottom:18px;">Formas de pagamento</div>
        <div class="flex flex-wrap gap-2">
          {payments.map((p) => (
            <span style={payChip} title={p.label}>
              <img src={p.src} alt={p.label} loading="lazy" style="height:18px; width:auto; display:block;" />
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Barra legal -->
    <div class="flex items-center justify-between gap-5 flex-wrap" style="margin-top:36px; padding:24px 0 30px; border-top:1px solid rgba(200,162,74,.18);">
      <span style="font-size:13px; color:#8a9079;">© {year} Hotel Cajueiro. Todos os direitos reservados.</span>
      <div class="flex gap-6" style="font-size:13px;">
        {socials.map(([label, href]: any) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">{label}</a>
        ))}
        <a href="/privacidade" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Privacidade</a>
        <a href="/termos" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Termos</a>
      </div>
    </div>
  </div>
</footer>
