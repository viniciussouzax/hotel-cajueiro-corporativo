---
/**
 * Footer.astro — rodapé enxuto: apenas a barra de direitos + políticas
 * (verde-escuro #26331C). As colunas foram removidas a pedido.
 */
import { readData } from '../../lib/readData';

const siteConfig = readData('siteConfig.json');

const year = new Date().getFullYear();
const brand = siteConfig.name || 'Hotel Cajueiro';
const socials: Array<[string, string]> = ([
  ['Instagram', siteConfig.social?.instagram],
  ['Facebook', siteConfig.social?.facebook],
  ['YouTube', siteConfig.social?.youtube],
  ['LinkedIn', siteConfig.social?.linkedin],
].filter(([, href]) => href)) as any;
---

<footer style="background:#26331C; color:#c3c8b6;">
  <div class="container-x">
    <div class="flex items-center justify-between gap-5 flex-wrap" style="padding:26px 0;">
      <span style="font-size:13px; color:#8a9079;">© {year} {brand} | CNPJ: 33.650.652/0001-20. Todos os direitos reservados.</span>
      <div class="flex gap-6" style="font-size:13px;">
        {socials.map(([label, href]: any) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">{label}</a>
        ))}
        <a href="/privacidade" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Privacidade</a>
        <a href="/termos" class="no-underline text-[#bcc1ad] hover:text-[#C8A24A] transition-colors">Termos</a>
      </div>
    </div>
  </div>
</footer>
