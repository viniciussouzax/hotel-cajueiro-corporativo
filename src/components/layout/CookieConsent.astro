---
import { readData } from '../../lib/readData';

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const cc = pluginsConfig?.cookieConsent;
const enabled = cc?.enabled !== false;
const headline = cc?.headline || 'Privacidade e Cookies';
const description = cc?.description || 'Utilizamos cookies para melhorar sua experiência. Ao clicar em "Aceitar", você concorda com nossa política de privacidade.';
const buttonAccept = cc?.buttonAccept || 'Aceitar';
const buttonReject = cc?.buttonReject || 'Ler Política';
const rejectUrl = cc?.rejectUrl || '/privacidade';
const position = cc?.position || 'bottom';

const posClass = position === 'top'
  ? 'fixed top-4 left-4 right-4 md:left-auto md:right-6 md:max-w-sm'
  : 'fixed bottom-6 left-4 right-4 md:left-auto md:right-6 md:max-w-sm';
const slideClass = position === 'top' ? '-translate-y-20' : 'translate-y-20';
---

{enabled && (
  <div
    id="cookie-banner"
    class={`${posClass} z-[100] transform ${slideClass} opacity-0 transition-all duration-500 pointer-events-none`}
    data-accept-text={buttonAccept}
  >
    <div class="bg-white text-slate-800 p-5 rounded-2xl shadow-2xl border border-gray-200">
      <div class="flex items-start gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background:var(--walker-primary,#FE4F70);">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-sm mb-1 text-slate-800">{headline}</h4>
          <p class="text-slate-500 text-xs leading-relaxed">{description}</p>
        </div>
      </div>
      <div class="flex gap-3">
        <button
          id="accept-cookies"
          class="flex-1 px-4 py-2.5 rounded-xl text-white font-bold text-sm transition-all"
          style="background:var(--walker-primary,#FE4F70);"
        >
          {buttonAccept}
        </button>
        <a
          href={rejectUrl}
          class="flex-1 px-4 py-2.5 rounded-xl bg-gray-100 hover:bg-gray-200 text-slate-700 font-bold text-sm text-center transition-all"
        >
          {buttonReject}
        </a>
      </div>
    </div>
  </div>
)}

<script>
(function() {
  var banner = document.getElementById('cookie-banner');
  var acceptBtn = document.getElementById('accept-cookies');

  if (!banner || !acceptBtn) return;

  var slideClass = banner.classList.contains('-translate-y-20') ? '-translate-y-20' : 'translate-y-20';

  // Show if not yet accepted
  if (!localStorage.getItem('cookies-accepted')) {
    setTimeout(function() {
      banner.classList.remove(slideClass, 'opacity-0', 'pointer-events-none');
    }, 1500);
  }

  acceptBtn.addEventListener('click', function() {
    localStorage.setItem('cookies-accepted', 'true');
    banner.classList.add(slideClass, 'opacity-0', 'pointer-events-none');
    // Emit event for GA/Pixel deferred loading
    window.dispatchEvent(new CustomEvent('cookies-accepted'));
  });
})();
</script>
