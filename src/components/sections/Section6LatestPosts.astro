---
import { getCollection } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';
import PostCardMedium from '../ui/PostCardMedium.astro';
import Sidebar from '../sidebar/Sidebar.astro';

interface Props {
  title?: string;
  limit?: number;
  btnText?: string;
  btnLink?: string;
}

const {
  title = "Publicações Recentes",
  limit = 6,
  btnText = "Ver Todos os Artigos",
  btnLink = "/blog",
} = Astro.props;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, limit);
---

<section class="py-12 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10">

      <!-- Posts coluna principal -->
      <div>
        <SectionHeader title={title} />

        {posts.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
            {posts.map(post => (
              <PostCardMedium
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                heroImage={post.data.heroImage}
                category={post.data.category}
                pubDate={post.data.pubDate}
              />
            ))}
          </div>
        ) : (
          <div class="py-16 text-center rounded-2xl bg-white border border-gray-200">
            <p class="text-slate-400">Nenhum post publicado ainda.</p>
          </div>
        )}

        {posts.length > 0 && (
          <div class="text-center">
            <a
              href={btnLink}
              class="inline-flex items-center gap-2 px-8 py-3 rounded-full border-2 border-primary-500 text-primary-500 font-bold text-sm hover:bg-primary-500 hover:text-white transition-all"
            >
              {btnText}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="hidden lg:block">
        <Sidebar />
      </div>
    </div>
  </div>
</section>
