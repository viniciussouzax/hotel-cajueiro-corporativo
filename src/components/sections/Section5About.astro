---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  title?: string;
  desc?: string;
  image?: string;
  btnText?: string;
  btnLink?: string;
  stats?: Stat[];
}

const {
  title = "Sobre Nós",
  desc = "",
  image = "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=2071&auto=format&fit=crop",
  btnText = "Saiba Mais",
  btnLink = "/sobre",
  stats = [],
} = Astro.props;
---

<section class="py-16 bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Imagem -->
      <div class="relative rounded-2xl overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-72 lg:h-96 object-cover rounded-2xl"
        />
        <!-- Decoração: card de stats sobreposto -->
        {stats.length > 0 && (
          <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-sm rounded-xl p-4 shadow-lg flex items-center justify-around">
            {stats.map(stat => (
              <div class="text-center">
                <p class="text-2xl font-bold text-primary-500">{stat.value}</p>
                <p class="text-slate-500 text-xs">{stat.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Conteúdo -->
      <div>
        <span class="inline-block bg-primary-100 text-primary-600 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">
          Sobre Nós
        </span>
        <h2 class="text-3xl font-bold text-slate-800 mb-4 leading-tight">{title}</h2>
        <p class="text-slate-500 leading-relaxed mb-6">{desc}</p>

        <a
          href={btnLink}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary-500 text-white font-bold text-sm hover:bg-primary-600 transition-colors shadow-md shadow-primary-500/20"
        >
          {btnText}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
