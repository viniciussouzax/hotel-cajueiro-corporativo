---
import { readData } from '../../lib/readData';
import { normalizeCategories, getCategorySlug } from '../../lib/categorySlug';

interface Category {
  name: string;
  count: number;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const allCategories = normalizeCategories(readData('categories.json', []));
---

<div class="bg-white rounded-2xl border border-gray-200 p-5">
  <h3 class="font-bold text-slate-800 text-sm uppercase tracking-wider mb-4 pb-3 border-b border-gray-100 relative">
    Categorias
    <span class="absolute bottom-0 left-0 w-12 h-0.5 bg-primary-500"></span>
  </h3>

  <ul class="space-y-2">
    {categories.map((cat) => (
      <li>
        <a
          href={`/categoria/${getCategorySlug(cat.name, allCategories)}`}
          class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-gray-50 group transition-colors"
        >
          <span class="text-slate-700 text-sm group-hover:text-primary-500 transition-colors flex items-center gap-2">
            <svg class="w-3 h-3 text-primary-500 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            {cat.name}
          </span>
          <span class="text-xs bg-primary-50 text-primary-600 font-bold px-2 py-0.5 rounded-full">
            {cat.count}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
