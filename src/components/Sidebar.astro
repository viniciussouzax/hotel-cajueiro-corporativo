---
import { BLOG_BASE } from '../lib/postUrl';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';
import { normalizeCategories, getCategorySlug, collectOrphanCategories } from '../lib/categorySlug';
const categoriesData = readData('categories.json', []);
const siteConfig = readData('siteConfig.json');

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const sidebarConfig = pluginsConfig?.emailList?.sidebar;
const sidebarEnabled = sidebarConfig?.enabled !== false;
const sidebarHeadline = sidebarConfig?.headline || 'Newsletter';
const sidebarSub = sidebarConfig?.subheadline || 'Junte-se a nossos leitores!';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const registered = normalizeCategories(categoriesData);
const postCats = [...new Set(posts.map((p: any) => p.data.category).filter(Boolean))];
const orphans = collectOrphanCategories(postCats, registered);
const allCategories = registered.length > 0 ? [...registered, ...orphans] : orphans;

const popularPosts = posts.slice(0, 5);
const carouselPosts = posts.slice(0, 3);

// Contagem de posts por categoria
const categoryCounts = allCategories.map(cat => ({
  name: cat.name,
  slug: cat.slug,
  count: posts.filter((p: any) => {
    const pc = (p.data.category || '').toLowerCase();
    return pc === cat.name.toLowerCase() || pc === cat.slug.toLowerCase();
  }).length,
}));
---

<div class="sidebar">

  <!-- widget about -->
  <div class="widget rounded">
    <div class="widget-about text-center" style="background-image: url('/images/map-bg.png'); background-size: cover; background-position: center; padding: 30px; border-radius: 5px;">
      {siteConfig.logo ? (
        <img src={siteConfig.logo} alt={siteConfig.name} class="mb-4" />
      ) : (
        <h4 class="mb-4" style="font-family: var(--walker-font-heading); color: var(--walker-dark);">{siteConfig.name}</h4>
      )}
      <p class="mb-4">{siteConfig.description}</p>
      <ul class="social-icons list-unstyled list-inline mb-0">
        {siteConfig.social?.facebook && (<li class="list-inline-item"><a href={siteConfig.social.facebook} target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>)}
        {siteConfig.social?.twitter && (<li class="list-inline-item"><a href={siteConfig.social.twitter} target="_blank" rel="noopener"><i class="fab fa-twitter"></i></a></li>)}
        {siteConfig.social?.instagram && (<li class="list-inline-item"><a href={siteConfig.social.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>)}
        {siteConfig.social?.pinterest && (<li class="list-inline-item"><a href={siteConfig.social.pinterest} target="_blank" rel="noopener"><i class="fab fa-pinterest"></i></a></li>)}
        {siteConfig.social?.youtube && (<li class="list-inline-item"><a href={siteConfig.social.youtube} target="_blank" rel="noopener"><i class="fab fa-youtube"></i></a></li>)}
      </ul>
    </div>
  </div>

  <!-- widget popular posts -->
  <div class="widget rounded">
    <div class="widget-header text-center">
      <h3 class="widget-title">Posts Populares</h3>
      <img src="/images/wave.svg" class="wave" alt="wave" />
    </div>
    <div class="widget-content">
      {popularPosts.map((post, i) => (
        <div class="post post-list-sm circle">
          <div class="thumb circle">
            <span class="number">{i + 1}</span>
            <a href={`${BLOG_BASE}/${post.slug}`}>
              <div class="inner">
                {post.data.heroImage ? (
                  <img src={post.data.heroImage} alt={post.data.title} />
                ) : (
                  <div style="background: #f5f5f5; width: 100%; height: 100%;"></div>
                )}
              </div>
            </a>
          </div>
          <div class="details clearfix">
            <h6 class="post-title my-0">
              <a href={`${BLOG_BASE}/${post.slug}`}>{post.data.title}</a>
            </h6>
            <ul class="meta list-inline mt-1 mb-0">
              <li class="list-inline-item">
                {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
              </li>
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- widget categories -->
  <div class="widget rounded">
    <div class="widget-header text-center">
      <h3 class="widget-title">Explorar Tópicos</h3>
      <img src="/images/wave.svg" class="wave" alt="wave" />
    </div>
    <div class="widget-content">
      <ul class="list">
        {categoryCounts.map(cat => (
          <li>
            <a href={`/categoria/${cat.slug}`}>{cat.name}</a>
            <span>({cat.count})</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- widget newsletter -->
  {sidebarEnabled && (
  <div class="widget rounded">
    <div class="widget-header text-center">
      <h3 class="widget-title">{sidebarHeadline}</h3>
      <img src="/images/wave.svg" class="wave" alt="wave" />
    </div>
    <div class="widget-content">
      <span class="newsletter-headline text-center mb-3">{sidebarSub}</span>
      <form id="sidebar-newsletter-form">
        <div class="mb-2">
          <input id="sidebar-newsletter-input" class="form-control w-100 text-center" placeholder="Seu e-mail…" type="email" required>
        </div>
        <button class="btn btn-default btn-full" type="submit">Inscrever-se</button>
      </form>
      <p id="sidebar-newsletter-msg" style="display:none; text-align:center; margin-top:0.5rem; font-size:0.8rem; font-weight:600;"></p>
      <span class="newsletter-privacy text-center mt-3">Ao se inscrever, você concorda com nossa <a href="/privacidade">Política de Privacidade</a></span>
    </div>
  </div>
  )}

  <!-- widget post carousel -->
  {carouselPosts.length > 0 && (
    <div class="widget rounded">
      <div class="widget-header text-center">
        <h3 class="widget-title">Destaques</h3>
        <img src="/images/wave.svg" class="wave" alt="wave" />
      </div>
      <div class="widget-content">
        <div class="post-carousel-widget">
          {carouselPosts.map(post => (
            <div class="post post-carousel">
              <div class="thumb rounded">
                {post.data.category && (
                  <a href={`/categoria/${getCategorySlug(post.data.category, allCategories)}`} class="category-badge position-absolute">{post.data.category}</a>
                )}
                <a href={`${BLOG_BASE}/${post.slug}`}>
                  <div class="inner">
                    {post.data.heroImage ? (
                      <img src={post.data.heroImage} alt={post.data.title} />
                    ) : (
                      <div style="background: #f5f5f5; width: 100%; height: 250px;"></div>
                    )}
                  </div>
                </a>
              </div>
              <h5 class="post-title mb-0 mt-4">
                <a href={`${BLOG_BASE}/${post.slug}`}>{post.data.title}</a>
              </h5>
              <ul class="meta list-inline mt-2 mb-0">
                <li class="list-inline-item">
                  {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                </li>
              </ul>
            </div>
          ))}
        </div>
        <!-- carousel arrows -->
        <div class="slick-arrows-bot">
          <button type="button" data-role="none" class="carousel-botNav-prev slick-custom-buttons" aria-label="Previous"><i class="icon-arrow-left"></i></button>
          <button type="button" data-role="none" class="carousel-botNav-next slick-custom-buttons" aria-label="Next"><i class="icon-arrow-right"></i></button>
        </div>
      </div>
    </div>
  )}

  <!-- widget tags -->
  <div class="widget rounded">
    <div class="widget-header text-center">
      <h3 class="widget-title">Tag Clouds</h3>
      <img src="/images/wave.svg" class="wave" alt="wave" />
    </div>
    <div class="widget-content">
      {allCategories.map(cat => (
        <a href={`/categoria/${cat.slug}`} class="tag">#{cat.name}</a>
      ))}
    </div>
  </div>

</div>

<script>
(function() {
    document.getElementById('sidebar-newsletter-form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        const input = document.getElementById('sidebar-newsletter-input') as HTMLInputElement | null;
        const btn = (e.currentTarget as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement | null;
        const msg = document.getElementById('sidebar-newsletter-msg') as HTMLElement | null;
        const email = input?.value?.trim();
        if (!email || !btn || !msg) return;

        const originalText = btn.textContent;
        btn.textContent = 'Enviando...';
        btn.disabled = true;
        msg.style.display = 'none';

        try {
            const res = await fetch('/api/subscribe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, source: 'widget' }),
            });
            const data = await res.json();

            if (data.success) {
                msg.textContent = data.message || 'Inscrito com sucesso!';
                msg.style.color = '#16a34a';
                msg.style.display = 'block';
                if (input) input.value = '';
                btn.textContent = 'Inscrito!';
            } else {
                msg.textContent = data.error || 'Erro ao inscrever.';
                msg.style.color = '#dc2626';
                msg.style.display = 'block';
                btn.textContent = originalText ?? 'Inscrever-se';
                btn.disabled = false;
            }
        } catch {
            msg.textContent = 'Erro de rede. Tente novamente.';
            msg.style.color = '#dc2626';
            msg.style.display = 'block';
            btn.textContent = originalText ?? 'Inscrever-se';
            btn.disabled = false;
        }
    });
})();
</script>
