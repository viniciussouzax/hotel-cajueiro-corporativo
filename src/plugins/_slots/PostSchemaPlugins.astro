---
interface Props {
  title: string;
  description: string;
  url: string;
  image?: string;
  datePublished?: string;
  authorName?: string;
  category?: string;
  videoUrl?: string;
}
const { title, description, url, image, datePublished, authorName, category, videoUrl } = Astro.props;
import SchemaMarkup from '../seo/SchemaMarkup.astro';
---
<SchemaMarkup
  title={title}
  description={description}
  url={url}
  image={image}
  datePublished={datePublished}
  authorName={authorName}
  category={category}
  videoUrl={videoUrl}
/>
