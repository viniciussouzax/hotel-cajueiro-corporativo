---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAboutPage } from '../lib/localPagesData';

const { aboutTitle, aboutParas, biz, region, phoneHref, waUrl, accent, accentInk, company, empty } = loadAboutPage();

const title = company ? `Quem somos | ${company}` : 'Quem somos';
const description = aboutParas[0] || `Conheça a ${company || 'nossa empresa'}.`;
---

<BaseLayout title={title} description={description}>

  <!-- ===== QUEM SOMOS — prosa + card de atendimento ===== -->
  <section class="bg-surface border-b border-rule">
    <div class="container-x pt-16 md:pt-20 pb-14 md:pb-16">
      <p class="mono uppercase text-ink-faint mb-5">a empresa</p>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 items-start">
        <div class="lg:col-span-2 max-w-prose-lg">
          <h1 class="font-display text-3xl md:text-4xl font-normal tracking-tight text-ink leading-[1.1] mb-6">{aboutTitle}</h1>
          {empty ? (
            <p class="text-ink-muted">
              Edite o conteúdo em
              <a href="/admin/local/empresa" class="underline underline-offset-4 hover:text-ink ml-1">/admin/local/empresa</a>.
            </p>
          ) : (
            aboutParas.map((p) => <p class="text-lg text-ink-muted leading-relaxed mb-4">{p}</p>)
          )}
        </div>

        <aside class="lg:col-span-1">
          <div class="bg-bg border border-border rounded-md p-6 lg:sticky lg:top-6">
            <p class="mono uppercase text-xs text-ink-faint mb-4">Atendimento</p>
            <dl class="space-y-3 text-sm">
              {region && (
                <div>
                  <dt class="text-ink-faint">Onde</dt>
                  <dd class="text-ink font-medium">{region} e região</dd>
                </div>
              )}
              {biz.hours && (
                <div>
                  <dt class="text-ink-faint">Horário</dt>
                  <dd class="text-ink font-medium">{biz.hours}</dd>
                </div>
              )}
              {biz.phone && (
                <div>
                  <dt class="text-ink-faint">Telefone</dt>
                  <dd><a href={phoneHref} class="text-ink font-medium hover:text-primary no-underline transition-colors">{biz.phone}</a></dd>
                </div>
              )}
            </dl>
            {waUrl && (
              <a href={waUrl} target="_blank" rel="noopener noreferrer"
                class="mt-5 w-full inline-flex items-center justify-center min-h-[44px] px-4 py-3 rounded font-semibold no-underline hover:brightness-90 transition-[filter]"
                style={`background-color: ${accent}; color: ${accentInk}`}>
                Falar no WhatsApp
              </a>
            )}
          </div>
        </aside>
      </div>
    </div>
  </section>

</BaseLayout>
