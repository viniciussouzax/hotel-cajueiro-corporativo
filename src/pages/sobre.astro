---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData } from '../lib/readData';

const sobreData = readData('sobre.json', {}) as any;
const siteConfig = readData('siteConfig.json');
const authorsData = readData('authors.json', []) as any[];

const hero = sobreData?.hero || {};
const content = sobreData?.content || {};
const seo = sobreData?.seo || {};

const authors = Array.isArray(authorsData) ? authorsData : [];

const title = seo.title || `Sobre ${siteConfig.name}`;
const description = seo.description || hero.desc || `Conheça ${siteConfig.name}`;
const ogImage = seo.image || hero.image || '';
---

<BaseLayout title={title} description={description} image={ogImage}>

  <!-- ===== HERO 2 colunas: texto + imagem ===== -->
  <section class="border-b border-rule">
    <div class="container-x pt-16 md:pt-20 pb-16 md:pb-20">
      <p class="mono uppercase text-ink-faint mb-8">sobre</p>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-start">
        <div class="md:col-span-7 md:order-1">
          <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-normal tracking-tight text-ink leading-[1.1] mb-8">
            {hero.title || `Conheça ${siteConfig.name}`}
          </h1>

          {hero.desc && (
            <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-prose-lg">
              {hero.desc}
            </p>
          )}

          {!hero.title && !hero.desc && (
            <p class="text-ink-muted">
              Edite essa página em <a href="/admin/sobre" class="underline underline-offset-4 hover:text-ink">/admin/sobre</a>.
            </p>
          )}
        </div>

        <div class="md:col-span-5 md:order-2">
          {hero.image ? (
            <img
              src={hero.image}
              alt={hero.title || 'Sobre'}
              class="w-full aspect-[4/5] object-cover rounded"
              loading="eager"
            />
          ) : (
            <div class="w-full aspect-[4/5] bg-elev border border-rule rounded flex items-center justify-center">
              <div class="text-center p-6">
                <p class="mono uppercase text-ink-faint mb-2">imagem</p>
                <p class="text-sm text-ink-faint">Adicione no /admin/sobre</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MISSÃO ===== -->
  {(content.missionTitle || content.missionText) && (
    <section class="border-b border-rule">
      <div class="container-x py-14 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
          <div class="md:col-span-4">
            <p class="mono uppercase text-ink-faint mb-4">missão</p>
            <h2 class="font-display text-2xl md:text-3xl font-normal leading-[1.1] tracking-tight text-ink">
              {content.missionTitle || 'Nossa missão'}
            </h2>
          </div>
          <div class="md:col-span-7 md:col-start-6">
            {content.missionText && (
              <p class="text-lg text-ink-muted leading-relaxed">
                {content.missionText}
              </p>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== EQUIPE: grid 3 cols (imagem em cima, nome+role+bio embaixo, socials) ===== -->
  {authors.length > 0 && (
    <section>
      <div class="container-x py-14 md:py-20">
        <div class="mb-12 md:mb-16">
          <p class="mono uppercase text-ink-faint mb-4">equipe</p>
          <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-normal leading-[1.1] tracking-tight text-ink max-w-2xl">
            {content.teamTitle || 'Quem escreve por aqui'}
          </h2>
          {content.teamText && (
            <p class="text-lg text-ink-muted leading-relaxed mt-5 max-w-2xl">
              {content.teamText}
            </p>
          )}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
          {authors.map((author: any) => {
            const social = author.social || {};
            const hasSocial = social.twitter || social.instagram || social.linkedin || social.website;
            return (
              <article class="group">
                <!-- Imagem acima -->
                {author.avatar ? (
                  <div class="aspect-[4/5] mb-6 overflow-hidden rounded">
                    <img
                      src={author.avatar}
                      alt={author.name}
                      class="w-full h-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-[4/5] mb-6 bg-elev border border-rule rounded flex items-center justify-center">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-ink-faint" aria-hidden="true">
                      <circle cx="12" cy="8" r="4"/>
                      <path d="M4 22v-2a8 8 0 0116 0v2"/>
                    </svg>
                  </div>
                )}

                <!-- Role -->
                {author.role && (
                  <p class="mono uppercase text-ink-faint mb-2">{author.role}</p>
                )}

                <!-- Nome -->
                <h3 class="font-sans font-semibold text-lg tracking-tight text-ink leading-tight mb-3">
                  {author.name}
                </h3>

                <!-- Bio -->
                {author.bio && (
                  <p class="text-base text-ink-muted leading-relaxed mb-5 line-clamp-4">
                    {author.bio}
                  </p>
                )}

                <!-- Redes sociais -->
                {hasSocial && (
                  <div class="flex items-center gap-4 mono uppercase text-ink-faint pt-4 border-t border-rule">
                    {social.twitter && (
                      <a href={social.twitter} target="_blank" rel="noopener" class="hover:text-ink transition-colors inline-flex items-center gap-1.5" aria-label={`Twitter de ${author.name}`}>
                        twitter
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                      </a>
                    )}
                    {social.instagram && (
                      <a href={social.instagram} target="_blank" rel="noopener" class="hover:text-ink transition-colors inline-flex items-center gap-1.5" aria-label={`Instagram de ${author.name}`}>
                        instagram
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                      </a>
                    )}
                    {social.linkedin && (
                      <a href={social.linkedin} target="_blank" rel="noopener" class="hover:text-ink transition-colors inline-flex items-center gap-1.5" aria-label={`LinkedIn de ${author.name}`}>
                        linkedin
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                      </a>
                    )}
                    {social.website && (
                      <a href={social.website} target="_blank" rel="noopener" class="hover:text-ink transition-colors inline-flex items-center gap-1.5" aria-label={`Site de ${author.name}`}>
                        site
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                      </a>
                    )}
                  </div>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
