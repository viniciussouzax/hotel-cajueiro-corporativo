---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import ImportPage from '../../plugins/wp-importer/ImportPage';
---
<AdminLayout title="Importar WordPress" activeSection="import-wp">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-ink">Importar do WordPress</h1>
        <p class="text-ink-muted mt-1">Importe posts, categorias e autores a partir de um arquivo de exportação WordPress (.xml).</p>
    </div>
    <ImportPage client:load />
</AdminLayout>
