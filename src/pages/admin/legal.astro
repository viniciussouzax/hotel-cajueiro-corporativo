---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import LegalEditor from '../../components/admin/LegalEditor';
---
<AdminLayout title="Privacidade & Termos" activeSection="legal">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-ink">Privacidade & Termos</h1>
        <p class="text-ink-muted mt-1">Edite a Política de Privacidade e os Termos de Uso do site.</p>
    </div>
    <LegalEditor client:load />
</AdminLayout>
