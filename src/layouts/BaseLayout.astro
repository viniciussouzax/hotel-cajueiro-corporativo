---
import '../styles/global.css';
import '@fontsource-variable/dm-sans'; // corpo (DM Sans) — auto-hospedado
// Títulos (Cormorant Garamond) — auto-hospedado, igual ao projeto de design (sem depender da CDN do Google).
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '@fontsource/cormorant-garamond/600-italic.css';
import { readData } from '../lib/readData';
import HeadPlugins from '../plugins/_slots/HeadPlugins.astro';
import BodyEndPlugins from '../plugins/_slots/BodyEndPlugins.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const siteConfig = readData('siteConfig.json');
const pluginsConfig = readData('pluginsConfig.json', {});
const gscVerificationTag = (pluginsConfig as any)?.searchConsole?.verificationTag?.trim() || '';

const primaryHex = siteConfig.theme?.primary || '#1c64c8';
// Combinações de fonte selecionáveis no admin (Configurações → Combinação de Fontes).
// Cada combo carrega as famílias que precisa via <link> no <head> (default = fontes do tema, já no global.css).
const FONT_MAP: Record<string, { display: string; body: string; href: string }> = {
  default:    { display: 'DM Sans Variable', body: 'DM Sans Variable', href: '' },
  inter:      { display: 'Inter', body: 'Inter', href: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' },
  outfit:     { display: 'Outfit', body: 'Inter', href: 'https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap' },
  roboto:     { display: 'Roboto', body: 'Open Sans', href: 'https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Open+Sans:wght@400;600&display=swap' },
  poppins:    { display: 'Poppins', body: 'Lora', href: 'https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Lora:wght@400;500&display=swap' },
  montserrat: { display: 'Montserrat', body: 'Merriweather', href: 'https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap' },
  playfair:   { display: 'Playfair Display', body: 'Source Sans 3', href: 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Sans+3:wght@400;600&display=swap' },
  lora:       { display: 'Lora', body: 'Merriweather', href: 'https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap' },
};
const font = FONT_MAP[siteConfig.theme?.font || 'default'] || FONT_MAP.default;

function hexToRgbTriplet(hex: string): string {
  const h = hex.replace('#', '').trim();
  if (h.length !== 6) return '28 100 200';
  const r = parseInt(h.substring(0, 2), 16);
  const g = parseInt(h.substring(2, 4), 16);
  const b = parseInt(h.substring(4, 6), 16);
  return `${r} ${g} ${b}`;
}
function soften(hex: string): string {
  const h = hex.replace('#', '').trim();
  if (h.length !== 6) return '228 235 247';
  const r = Math.round(parseInt(h.substring(0, 2), 16) * 0.1 + 255 * 0.9);
  const g = Math.round(parseInt(h.substring(2, 4), 16) * 0.1 + 255 * 0.9);
  const b = Math.round(parseInt(h.substring(4, 6), 16) * 0.1 + 255 * 0.9);
  return `${r} ${g} ${b}`;
}

const cssVars = `
  --c-primary: ${hexToRgbTriplet(primaryHex)};
  --c-primary-soft: ${soften(primaryHex)};
  --font-display: '${font.display}', Georgia, system-ui, sans-serif;
  --font-body: '${font.body}', system-ui, -apple-system, sans-serif;
`;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  bodyClass?: string;
  /** Nav transparente sobreposta à hero (não-fixa). Usado na home e nas páginas de pacote. */
  transparentHeader?: boolean;
}

const defaultTitle = siteConfig.seo?.title || siteConfig.name;
const {
  title = defaultTitle,
  description = siteConfig.seo?.description || siteConfig.description,
  image = '',
  type = 'website',
  bodyClass = '',
  transparentHeader = false,
} = Astro.props;

const formattedTitle = title === defaultTitle ? title : `${title} | ${siteConfig.name}`;
// Normaliza a base: domínio salvo no admin pode vir sem protocolo (ex.: "exemplo.com.br").
// new URL() exige base absoluta — sem isso o build quebra com "Invalid URL" (BUILD-05).
const rawSiteUrl = (siteConfig.url || Astro.url.origin || '').trim();
const siteUrl = rawSiteUrl && !/^https?:\/\//i.test(rawSiteUrl) ? `https://${rawSiteUrl}` : rawSiteUrl;
// Nenhum new URL com base de dado do usuário pode derrubar o build → try/catch com fallback seguro.
function toAbsoluteUrl(path: string, base: string): string {
  if (!path) return '';
  if (/^https?:\/\//i.test(path)) return path;
  try {
    return new URL(path, base).toString();
  } catch {
    return path; // fallback: path relativo (não derruba o build)
  }
}
const socialImage = toAbsoluteUrl(image || '/images/hero-cajueiro.jpg', siteUrl);
const canonicalUrl = Astro.url.href;

// Dados estruturados (Schema.org / JSON-LD) — ajudam indexação e rich results.
const biz = readData('localBusiness.json', {}) as any;
const bizPhone = String(biz.phone || siteConfig.contact?.phone || '').replace(/\D/g, '');
const socialLinks = Object.values(siteConfig.social || {}).filter((u: any) => typeof u === 'string' && u.trim());
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: siteConfig.name,
  description: siteConfig.description,
  url: siteUrl || canonicalUrl,
  ...(socialImage ? { image: socialImage } : {}),
  ...(bizPhone ? { telephone: `+55${bizPhone}` } : {}),
  ...(biz.email ? { email: biz.email } : {}),
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rua Avedis Simonian, 1177, Guaiúba',
    addressLocality: 'Guarujá',
    addressRegion: 'SP',
    addressCountry: 'BR',
  },
  ...(socialLinks.length ? { sameAs: socialLinks } : {}),
};
---

<!DOCTYPE html>
<html lang={siteConfig.language || 'pt-BR'} style={cssVars}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{formattedTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={siteConfig.favicon || '/favicon.svg'} />
  <link rel="apple-touch-icon" href={siteConfig.favicon || '/favicon-caju.png'} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow, max-image-preview:large" />
  <meta name="author" content={siteConfig.author || siteConfig.name} />
  <meta name="theme-color" content={siteConfig.theme?.primary || '#55703A'} />
  {font.href && <link rel="stylesheet" href={font.href} />}

  {gscVerificationTag && (
    gscVerificationTag.startsWith('<')
      ? <Fragment set:html={gscVerificationTag} />
      : <meta name="google-site-verification" content={gscVerificationTag} />
  )}

  <!-- Open Graph (Facebook, WhatsApp, LinkedIn, etc.) -->
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:locale" content={(siteConfig.language || 'pt-BR').replace('-', '_')} />
  <meta property="og:title" content={formattedTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  {socialImage && <meta property="og:image" content={socialImage} />}
  {socialImage && <meta property="og:image:alt" content={formattedTitle} />}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={formattedTitle} />
  <meta name="twitter:description" content={description} />
  {socialImage && <meta name="twitter:image" content={socialImage} />}
  {socialImage && <meta name="twitter:image:alt" content={formattedTitle} />}

  <!-- Dados estruturados (Schema.org) -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <HeadPlugins />
</head>

<body class={bodyClass}>
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:bg-ink focus:text-bg focus:px-4 focus:py-2 focus:rounded focus:mono">
    pular pro conteúdo
  </a>

  <Header overlay={transparentHeader} />

  <main id="main">
    <slot />
  </main>

  <Footer />

  <BodyEndPlugins />
</body>
</html>
