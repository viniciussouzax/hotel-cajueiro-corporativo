{
  "id": "backup-feature",
  "date": "2026-05-26",
  "summary": "Adiciona rota /admin/backup com export/import de posts (.zip)",
  "applicable_to": "msia-scaffold-based Astro sites",
  "risk_level": "low",
  "additive_only": true,
  "breaking_changes": [],
  "automated": true,
  "entrypoint": "apply.mjs",
  "entrypoint_args": "<repoPath>",
  "exit_codes": {
    "0": "success",
    "1": "expected failure (prereqs / conflicts / build broken) — see stdout JSON",
    "2": "usage error"
  },
  "files_added": [
    { "from": "files/repoIo.ts",         "to": "src/lib/repoIo.ts" },
    { "from": "files/export.ts",         "to": "src/pages/api/admin/export.ts" },
    { "from": "files/import.ts",         "to": "src/pages/api/admin/import.ts" },
    { "from": "files/BackupManager.tsx", "to": "src/components/admin/BackupManager.tsx" },
    { "from": "files/backup.astro",      "to": "src/pages/admin/backup.astro" }
  ],
  "files_patched": [
    { "path": "src/components/admin/AdminNav.tsx", "patches": ["FileArchive import", "Backup NavLink"] }
  ],
  "deps_added": [
    { "name": "jszip", "version": "^3.10.1" }
  ],
  "validation": [
    "bun run build returns exit 0"
  ],
  "post_deploy_check": "GET /admin/backup returns 200 (after login)",
  "rollback": "git revert <commit>",
  "commit_message_template": "feat: add backup feature (import/export de posts)\n\n- /admin/backup: nova rota com upload/download de zip\n- Posts (markdown) + imagens referenciadas\n- Preview de conflitos antes de aplicar import\n- repoIo.ts: helper dev fs vs prod GitHub\n\nvia migration-kit/2026-05-26-backup-feature"
}
